# Copy to .env and fill in. Never commit .env.

# LINE Developers の LIFF ID
REACT_APP_LIFF_ID=

# 連携用 linkToken を返すバックエンド（例: API Gateway + Lambda）
REACT_APP_ACCOUNT_LINK_API=

# Cognito ID トークンを Authorization ヘッダに載せ、nonce を返す API の URL
REACT_APP_NONCE_API=

# 参考: Lambda 側の推奨 env（backend側）
# LINE_CHANNEL_ACCESS_TOKEN=...
# LINE_CHANNEL_ID=...
# ALLOWED_ORIGINS=https://example.com,http://localhost:3000

# 任意: ブラウザ外デバッグ用の LINE アクセストークン（本番では未設定推奨）
# REACT_APP_DEMO_ACCES_TOKEN=
